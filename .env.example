# API base URL — point at your running chanakya-astra-service instance
VITE_API_BASE_URL=http://localhost:3333

# N8N chatbot webhook (full URL to the chat endpoint)
VITE_N8N_CHAT_WEBHOOK_URL=

# Google Maps JS API key (only used if maps are enabled)
VITE_GOOGLE_MAPS_API_KEY=

# Razorpay public key id (test or live)
VITE_RAZORPAY_KEY_ID=
